# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Entornos virtuales ───────────────────────
venv/
env/
.env
.venv

# ── Jupyter ──────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Outputs temporales ───────────────────────
*.log
*.tmp

# ── Manuscrito (no versionar borradores Word) ─
05_manuscrito/*.docx
05_manuscrito/*.doc
05_manuscrito/~$*

# ── Sistema operativo ────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ─────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Datos sensibles ──────────────────────────
.env
secrets.yaml

# ── Archivos grandes de datos crudos ─────────
# ── Datos crudos, procesados y outputs (se archivan en Zenodo) ───────────
# Los datos NO se versionan en GitHub — solo el código
01_datos_crudos/
02_datos_procesados/
04_outputs/

# Excepción: mantener estructura de carpetas con .gitkeep
!01_datos_crudos/**/.gitkeep
!02_datos_procesados/.gitkeep
!04_outputs/**/.gitkeep
